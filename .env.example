# ── AI Keys ──────────────────────────────────────────────────────────────────
# Get free Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get free Groq key (fallback): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Appwrite ──────────────────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_appwrite_server_api_key

# ── Appwrite Database / Collection IDs ───────────────────────────────────────
APPWRITE_DB_ID=Ekthaa_db
APPWRITE_USERS_COLLECTION=users
APPWRITE_TRANSACTIONS_COLLECTION=transactions
APPWRITE_BUSINESSES_COLLECTION=businesses

# ── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key
FLASK_ENV=development
PORT=5001
